# Convergence — environment template. Copy to `.env` and fill in only what you
# use. NOTHING here is required to run the demo or the engine: the core is
# stdlib-only and every chat backend degrades to the deterministic narrator when
# its key/CLI is missing. `.env` is gitignored; never commit real keys.

# --- optional conversational backends (convergence/adapters/) ---
ANTHROPIC_API_KEY=        # --model claude
OPENAI_API_KEY=           # --model openai
XAI_API_KEY=              # --model grok (xAI OpenAI-compatible API); GROK_API_KEY also accepted
GEMINI_API_KEY=           # --model gemini (API-key path; the gemini CLI path needs no key)

# --- web server bind (web/server.py) ---
CONVERGENCE_HOST=127.0.0.1   # set to 0.0.0.0 only to expose beyond localhost (e.g. in Docker)
CONVERGENCE_PORT=8765

# --- web server auth (optional) ---
# If set, /api/chat requires a matching `X-API-Key` request header. Leave empty
# for localhost dev; set it for any exposed deployment, since /api/chat proxies
# to paid LLM backends.
CONVERGENCE_API_KEY=
